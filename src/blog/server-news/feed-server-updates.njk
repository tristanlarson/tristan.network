---
permalink: /blog/server-news/feed.xml
eleventyExcludeFromCollections: true
---
<?xml version="1.0" encoding="utf-8"?>
<feed xmlns="http://www.w3.org/2005/Atom">
    <title>{{ site.title }} — Server News</title>
    <link href="{{ site.url }}/blog/server-news/feed.xml" rel="self"/>
    <link href="{{ site.url }}/blog/server-news/"/>
    <updated>{{ collections.serverNews | getNewestCollectionItemDate | dateToRfc3339 }}</updated>
    <id>{{ site.url }}/blog/server-news/</id>
    <author><name>{{ site.author }}</name></author>
    {% for post in collections.serverNews %}
    <entry>
        <title>{{ post.data.title }}</title>
        <link href="{{ site.url }}{{ post.url }}"/>
        <updated>{{ post.date | dateToRfc3339 }}</updated>
        <id>{{ site.url }}{{ post.url }}</id>
        <summary>{{ post.data.description }}</summary>
        <content type="html">{{ post.templateContent | htmlToAbsoluteUrls(site.url) | safe }}</content>
    </entry>
    {% endfor %}
</feed>
