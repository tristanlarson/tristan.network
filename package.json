{
  "name": "my-site",
  "version": "1.0.0",
  "scripts": {
    "dev": "npm-run-all --parallel eleventy:watch styles:watch",
    "build": "npm-run-all styles:build eleventy:build",
    "eleventy:watch": "npx @11ty/eleventy --serve",
    "eleventy:build": "npx @11ty/eleventy",
    "styles:watch": "sass src/assets/sass:dist/assets/css --watch --no-source-map",
    "styles:build": "sass src/assets/sass:dist/assets/css --no-source-map"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.0.0",
    "@11ty/eleventy-plugin-rss": "^2.0.0",
    "npm-run-all": "^4.1.5",
    "sass": "^1.97.3"
  }
}
